# 🤖 Variáveis de Ambiente para Discloud - BOT DISCORD

# Token do Bot Discord (obtenha em: https://discord.com/developers/applications)
DISCORD_TOKEN=seu_token_bot_aqui

# ID do dono do bot (seu Discord ID)
DONO_ID=1468059815052968009

# URL do servidor API (pode usar Render ou Discloud)
# Opção 1: Render (recomendado para API)
SERVIDOR_URL=https://neoreplay-api.onrender.com

# Opção 2: Discloud (se houver API também em Discloud)
# SERVIDOR_URL=https://meubotlicencas-api.discloud.app

# Secret da API (deve corresponder com o servidor)
API_SECRET=seu_token_secreto_aqui
