# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🤖 BOT DISCORD - Bot de Gerenciamento de Licenças
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Token do Bot Discord. Pegue em https://discord.com/developers/applications
# ⚠️ NUNCA compartilhe seu token!
DISCORD_TOKEN=seu_token_do_bot_aqui

# ID do dono do bot (seu ID de usuário no Discord)
# Para pegar seu ID, ative Developer Mode no Discord e clique com botão direito em você mesmo
DONO_ID=seu_id_numerado_aqui

# URL do servidor API (Site Flask no Render)
# Exemplo: https://neoreplay.onrender.com
SERVIDOR_URL=https://neoreplay.onrender.com

# Token secreto para autenticar requisições ao servidor
# ⚠️ DEVE SER O MESMO QUE EM Site/.env !
API_SECRET=neoreplay_api_secret_1468059815052968009
